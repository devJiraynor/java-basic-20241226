// 클래스 : 공통된 속성과 기능을 정의한 것
// [접근제어자] class 클래스명 { 속성, 기능 }
class ExampleClass1 {
	
	// 속성: 객체가 가지는 정보나 상태의 정의
	// 일반적으로 변수 형태로 표현
	int attribute1;
	double attribute2;
	
}

// 스마트폰
// - 가로 길이
// - 세로 길이
// - 운영체제
